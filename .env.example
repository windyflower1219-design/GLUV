# ===========================
# GLUV 환경 변수 설정 파일
# ===========================
# 이 파일을 복사해 .env.local로 만들고 실제 값을 입력하세요

# ---------------------------
# Firebase 설정
# ---------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000

# ---------------------------
# Firebase Admin (서버 전용 — API 라우트의 ID Token 검증용)
# Firebase Console > 프로젝트 설정 > 서비스 계정 > "새 비공개 키 생성"으로 받은 JSON에서 추출
# PRIVATE_KEY 의 줄바꿈은 \n 으로 이스케이프해서 한 줄로 넣으세요.
# ---------------------------
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXX\n-----END PRIVATE KEY-----\n"

# ---------------------------
# Neon Postgres
# ---------------------------
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# ---------------------------
# DB 마이그레이션 가드 (선택)
# 설정하면 /api/db/init 호출 시 Authorization: Bearer <token> 일치할 때만 실행
# ---------------------------
ADMIN_INIT_TOKEN=

# ---------------------------
# Google Gemini API (인사이트 생성용)
# Google AI Studio에서 발급: https://aistudio.google.com/apikey
# 서버사이드 전용 키(GEMINI_API_KEY)를 권장합니다 (보안)
# ---------------------------
GEMINI_API_KEY=your-gemini-api-key
# 아래는 하위호환용 (기존에 NEXT_PUBLIC으로 설정한 경우)
NEXT_PUBLIC_GEMINI_API_KEY=your-gemini-api-key

# parse-meal 모델 체인 (선택)
# - PRIMARY: 한식 recall이 좋은 모델. 기본 gemini-2.5-flash
# - FALLBACK: PRIMARY가 rate-limit/오류일 때 사용. 기본 gemma-3-27b-it (14,400 RPD 무료)
GEMINI_MODEL_PRIMARY=gemini-2.5-flash
GEMINI_MODEL_FALLBACK=gemma-3-27b-it

# ---------------------------
# OpenAI API (식단 음성 파싱용)
# OpenAI Platform에서 발급: https://platform.openai.com/api-keys
# 서버사이드 전용 키(OPENAI_API_KEY)를 권장합니다 (보안)
# ---------------------------
OPENAI_API_KEY=your-openai-api-key
# 아래는 하위호환용 (기존에 NEXT_PUBLIC으로 설정한 경우)
NEXT_PUBLIC_OPENAI_API_KEY=your-openai-api-key

# ---------------------------
# 공공데이터포털 식품영양성분 API
# ---------------------------
FOOD_API_KEY=your-food-api-key

# ---------------------------
# Anthropic API (GAN Loop 전용 — Sonnet=Generator / Haiku=Discriminator)
# https://console.anthropic.com/settings/keys
# scripts/gan-loop/ 에서만 사용되며, 앱 런타임에는 사용되지 않습니다.
# ---------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key

